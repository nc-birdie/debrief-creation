generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users ────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  username    String   @unique // OS username, auto-detected
  displayName String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns Campaign[]
}

// ── Core Models ──────────────────────────────────────────────────────────

model Campaign {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String   @default("")
  status          String   @default("setup") // setup | in_progress | completed
  currentStep     Int      @default(1)
  briefAssessment    String?  @db.Text // JSON: assessment result from AI
  interactiveDesign  String?  @db.Text // JSON: generated immersive page design
  createdById        String?
  createdBy       User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sources          Source[]
  steps            StepState[]
  agentRuns        AgentRun[]
  knowledgeEntries KnowledgeEntry[]
  artefacts        Artefact[]

  @@index([createdById])
}

model Source {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name       String
  filePath   String
  fileType   String   @default("text") // text | pdf | markdown | notes
  sizeBytes  Int      @default(0)
  summary    String?  @db.Text
  ingested   Boolean  @default(false)
  createdAt  DateTime @default(now())

  knowledgeEntries KnowledgeEntry[]

  @@index([campaignId])
}

model KnowledgeEntry {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  area       String   // e.g. "product_technology", "market_context"
  title      String
  content    String   @db.Text
  sourceId   String?
  source     Source?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, area])
}

model StepState {
  id            String    @id @default(cuid())
  campaignId    String
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stepNumber    Int
  status        String    @default("pending") // pending | generating | review | approved | skipped
  aiDraft       String?   @db.Text
  userEdits     String?   @db.Text
  finalOutput   String?   @db.Text
  knowledgeGaps String    @default("[]") @db.Text // JSON array
  decisions     String    @default("[]") @db.Text // JSON array
  generatedAt   DateTime?
  approvedAt    DateTime?
  updatedAt     DateTime  @updatedAt

  @@unique([campaignId, stepNumber])
  @@index([campaignId])
}

model AgentRun {
  id           String    @id @default(cuid())
  campaignId   String
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stepNumber   Int
  phase        String    @default("generate") // generate | research | refine
  status       String    @default("pending")  // pending | running | completed | failed | cancelled
  systemPrompt String    @default("") @db.Text
  prompt       String    @default("") @db.Text
  result       String?   @db.Text
  turnsUsed    Int       @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  messages AgentMessage[]

  @@index([campaignId])
}

model AgentMessage {
  id         String   @id @default(cuid())
  runId      String
  run        AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  role       String   // system | user | assistant
  content    String   @db.Text
  turnNumber Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([runId])
}

// ── Artefacts ────────────────────────────────────────────────────────────

model Artefact {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category    String   // research | direction_setting
  type        String   // e.g. "market_research", "message_house", "swot", "custom"
  name        String
  description String   @default("") @db.Text
  content     String   @default("") @db.Text // markdown content
  status      String   @default("draft") // draft | final
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
  @@index([campaignId, category])
}

// ── Admin Configuration ──────────────────────────────────────────────────

// ── Briefing Template ────────────────────────────────────────────────────

model BriefingCategory {
  id        String   @id @default(cuid())
  label     String
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions      BriefingTemplateQuestion[]
  researchAgent  ResearchAgentDef?
}

model BriefingTemplateQuestion {
  id         String           @id @default(cuid())
  categoryId String
  category   BriefingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  question   String           @db.Text
  enabled    Boolean          @default(true)
  sortOrder  Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([categoryId])
}

// ── Research Agents (one per briefing category) ─────────────────────────

model ResearchAgentDef {
  id           String           @id @default(cuid())
  categoryId   String           @unique
  category     BriefingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name         String
  instructions String           @default("") @db.Text // System prompt / research instructions
  allowedTools String           @default("[\"WebSearch\",\"WebFetch\"]") // JSON array
  maxTurns     Int              @default(10)
  enabled      Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

// ── Step Definitions (dynamic, editable from admin) ──────────────────────

model StepDef {
  id                 String   @id @default(cuid())
  number             Int      @unique
  title              String
  shortTitle         String
  description        String   @default("") @db.Text
  dependsOn          String   @default("[]")  // JSON array of step numbers
  promptHint         String   @default("") @db.Text
  // Config
  customInstructions String   @default("") @db.Text
  outputFormat       String   @default("") @db.Text
  outputDisplay      String   @default("prose") // prose | bullet-cards | table | kpi-grid | statement-cards
  allowedTools       String   @default("[]") // JSON array of tool names
  maxTurns           Int      @default(10)
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
